---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	route(route)
	extract_features(extract_features)
	expand_seeds(expand_seeds)
	retrieve_one(retrieve_one)
	fuse_scores(fuse_scores)
	check_sufficiency(check_sufficiency)
	clarify(clarify)
	build_answer_contract(build_answer_contract)
	render_narrative(render_narrative)
	push(push)
	__end__([<p>__end__</p>]):::last
	__start__ --> route;
	build_answer_contract --> render_narrative;
	check_sufficiency -. &nbsp;sufficient&nbsp; .-> build_answer_contract;
	check_sufficiency -. &nbsp;insufficient&nbsp; .-> clarify;
	clarify --> push;
	expand_seeds -.-> fuse_scores;
	expand_seeds -.-> retrieve_one;
	extract_features --> expand_seeds;
	fuse_scores --> check_sufficiency;
	render_narrative --> push;
	retrieve_one --> fuse_scores;
	route --> extract_features;
	push --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
